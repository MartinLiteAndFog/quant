# ---- Data / backtest (optional) ----
EXCHANGE=kucoin
MARKET_TYPE=futures
SYMBOL=SOL/USDT
TIMEFRAME=1m
LIMIT=500
DATA_DIR=data/raw

# ---- Live: KuCoin Futures (Perps) – nur diese für Webhook/Dashboard ----
# Ticker & Orders laufen über KuCoin Futures API (kein Spot).
# KuCoin: API Management → Create API → Berechtigung "Futures" aktivieren.
KUCOIN_FUTURES_API_KEY=your_api_key_here
KUCOIN_FUTURES_API_SECRET=your_api_secret_here
KUCOIN_FUTURES_PASSPHRASE=your_passphrase_here

# ---- Webhook (optional: Token für TradingView-Webhook) ----
# WEBHOOK_TOKEN=secret

# ---- Live-Monitoring ----
# QUANT_LIVE_DIR=data/live
# SIGNALS_DIR=data/signals

# ---- Regime store / dashboard data sources ----
# Environment-configurable regime DB path (SQLite, default shown).
# REGIME_DB_PATH=data/live/regime.db
#
# Optional dashboard data sources (if omitted, defaults are used):
# DASHBOARD_RENKO_PARQUET=data/live/renko_latest.parquet
# DASHBOARD_TRADES_PARQUET=data/live/trades.parquet
# DASHBOARD_LEVELS_JSON=data/live/execution_state.json
#
# Optional background updater for dashboard Renko cache:
# ENABLE_DASHBOARD_RENKO_UPDATER=1
# DASHBOARD_RENKO_BOX=0.1
# DASHBOARD_RENKO_DAYS_BACK=14
# DASHBOARD_RENKO_STEP_HOURS=6
# DASHBOARD_RENKO_POLL_SEC=300

# ---- Live execution worker safety gates ----
# LIVE_TRADING_ENABLED=0
# LIVE_EXECUTOR_DRY_RUN=1
# LIVE_EXECUTOR_MAX_EUR=20
# LIVE_EXECUTOR_LEVERAGE=1
# LIVE_EXECUTOR_SYMBOL_ALLOWLIST=SOLUSDT,SOL-USDT
# LIVE_EXECUTOR_POLL_SEC=5
# LIVE_EXECUTOR_STATE=data/live/live_executor_state.json
# LIVE_TRAILING_STATE=data/live/live_trailing_state.json
# LIVE_TTP_TRAIL_PCT=0.012
# LIVE_WAIT_SL_PCT=0.02

# IMBA signal worker defaults
# LIVE_IMBA_LOOKBACK=250
# LIVE_DEFAULT_GATE_ON=1
